{
  "name": "easynr10",
  "private": true,
  "version": "2.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:api": "bun run --filter @easynr10/api dev",
    "dev:web": "bun run --filter @easynr10/web dev",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "oxlint apps packages",
    "db:generate": "bun run --filter @easynr10/db generate",
    "db:migrate": "bun run --filter @easynr10/db migrate",
    "db:seed": "bun run --filter @easynr10/db seed"
  },
  "devDependencies": {
    "oxlint": "^1.41.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  }
}
