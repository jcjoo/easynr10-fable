# Copie para .env e ajuste. NUNCA commite o .env.
# Config central — usada pelo dev local (bun) E pelos dois docker-compose
# (substituição ${VAR}; sem .env, os compose usam estes mesmos defaults).
# Obs.: a stack completa e a infra de dev compartilham MINIO_PORT — não suba as duas ao mesmo tempo.

# ── Portas publicadas no host ──────────────────────────────────────────────
WEB_PORT=8081
# Postgres da stack completa (acesso externo: Beekeeper etc.)
DB_PORT=5434
# 9000/9001 do host são de outro projeto (site-minio) → 9100/9101.
MINIO_PORT=9100
MINIO_CONSOLE_PORT=9101
# Infra de dev (docker-compose.dev): 5433 evita conflito com o Postgres do legado.
DEV_DB_PORT=5433
DEV_GOTENBERG_PORT=3010
DEV_SMTP_PORT=1025
DEV_MAILPIT_UI_PORT=8025

# ── Credenciais compartilhadas (dev/stack) ─────────────────────────────────
POSTGRES_USER=easynr10
POSTGRES_PASSWORD=easynr10
POSTGRES_DB=easynr10
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=easynr10
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
BETTER_AUTH_SECRET=troque-por-um-segredo-forte

# Google OAuth (opcional em dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── API em dev local (bun run dev:api) — aponta para a infra de dev ────────
PORT=3000
FRONTEND_URL=http://localhost:5173
BETTER_AUTH_URL=http://localhost:3000
DATABASE_URL=postgres://easynr10:easynr10@localhost:5433/easynr10
S3_ENDPOINT=http://localhost:9100
S3_PUBLIC_ENDPOINT=http://localhost:9100
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=easynr10@localhost
GOTENBERG_URL=http://localhost:3010
